					</div><!-- END: col-sm-12 -->
					<!-- <a title="Phòng chống tội phạm" href="/vi/news/antt-trong-tinh"><h2>Phòng chống tội phạm</h2></a>
					-->
					<!-- <div class="col-sm-24" >				
						<div class="feat-cap">
							<a href="/vi/news/antt-trong-tinh/canh-giac-hinh-thuc-mao-danh-co-quan-nha-nuoc-lua-dao-goi-ho-tro-tet-tro-cap-tet-dip-can-tet-nguyen-dan-2026-9238.html" title="Cảnh giác hình thức mạo danh cơ quan nhà nước lừa đảo gói “Hỗ trợ tết”, “Trợ cấp tết” dịp cận Tết Nguyên đán 2026."><h3 class="post-title">Cảnh giác hình thức mạo danh cơ quan nhà nước lừa đảo gói “Hỗ trợ tết”, “Trợ cấp tết” dịp cận Tết Nguyên đán 2026.</h3></a>

							<div class="metainfo"> -->
								<!-- <span><i class="fa fa-user"></i> Minh Quy - CAP Hoài Nhơn Nam</span> -->
								<!-- <span><i class="fa fa-calendar"></i> 29/01/2026</span>
								<span><i class="fa fa-eye"></i> 1165</span>
